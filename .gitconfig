[core]
	autocrlf = false
	pager = less -FRX
	editor = nvim
[push]
  autoSetupRemote = true
[pull]
  rebase = true
[alias]
	ss = status --short
	sw = switch
	ssufa = status --short --untracked-files=all
	l = log -7 --graph --pretty=format:\"%C(auto)%h%d%Creset %s %C(green)%cn%Creset %C(cyan)(%cr)%Creset\"
	last = l -1
	co = checkout
	c = commit --verbose
	b = branch
	p = push
	pl = pull
	branches = "!git branch && git branch --remote"
	cm = commit --verbose --message
	aa = add --all
	aac = "!git add --all && git commit --verbose"
	aacp = "!git add --all && git commit --verbose && git push"
	aacpf = "!git add --all && git commit --verbose && git push --force-with-lease"
	wt = worktree
	fpa = fetch --prune --all
	pf = push --force-with-lease
	ca = commit --verbose --amend
	aaca = "!git add --all && git commit --verbose --amend"
	cane = commit --verbose --amend --no-edit
	aacm = "!git add --all && git commit --verbose --message"
	aacane = "!git add --all && git commit --verbose --amend --no-edit"
	canep = "!git commit --verbose --amend --no-edit && git push"
	canepf = "!git commit --verbose --amend --no-edit && git push --force-with-lease"
	aacapf = "!git add --all && git commit --verbose --amend && git push --force-with-lease"
	aacanepf = "!git add --all && git commit --verbose --amend --no-edit && git push --force-with-lease"
	cp = "!git commit --verbose && git push"
	aacp = "!git add -all && git commit --verbose && git push"
	aacpf = "!git add -all && git commit --verbose && git push --force-with-lease"
	wt = worktree
	co = checkout
	smfe = submodule foreach
	skipped = !git ls-files -v | grep \"^S\"
	skip = update-index --skip-worktree
	no-skip = update-index --no-skip-worktree
	rsh1 = "!git reset --soft HEAD~1"